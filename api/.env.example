# ============================================
# Environment Configuration
# Copy this file to .env and fill in your values
# ============================================

# Node Environment (development, test, production)
NODE_ENV=development

# Server Port
PORT=5000

# Database Configuration (PostgreSQL)
PGHOST=localhost
PGUSER=your_db_username
PGPASSWORD=your_db_password
PGDATABASE=your_db_name

# JWT Secrets (min 32 characters each)
# Generate strong random strings for these
JWT_SECRET_KEY=your_32_char_min_secret_key_here
JWT_SECRET_KEY_REFRESH=your_32_char_min_refresh_secret_here

# Frontend URL (for CORS)
REACT_APP_UI_URL=http://localhost:3000
