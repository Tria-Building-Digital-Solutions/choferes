{
  "name": "api",
  "version": "1.0.0",
  "main": "index.js",
  "scripts": {
    "build": "npm install && tsc && mkdir -p dist/config && cp src/config/config.js dist/config/config.js",
    "start": "node dist/server.js",
    "dev": "ts-node src/server.ts",
    "migrate:dev": "npx sequelize-cli db:migrate --config src/config/config.js",
    "migrate:prod": "NODE_ENV=production npx sequelize-cli db:migrate --config src/config/config.js",
    "seed:dev": "npx sequelize-cli db:seed:all --config src/config/config.js",
    "undo:seed:dev": "npx sequelize-cli db:seed:undo:all --config src/config/config.js",
    "seed:prod": "NODE_ENV=production npx sequelize-cli db:seed:all --config src/config/config.js",
    "undo:seed:prod": "NODE_ENV=production npx sequelize-cli db:seed:undo:all --config src/config/config.js",
    "lint": "eslint 'src/**/*.{js,jsx,ts,tsx}'",
    "lint:fix": "eslint 'src/**/*.{js,jsx,ts,tsx}' --fix",
    "format": "prettier --write \"src/**/*.{js,jsx,ts,tsx,json,css,md}\""
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "description": "",
  "dependencies": {
    "@types/express": "^4.17.21",
    "@types/node": "^22.5.5",
    "bcrypt": "^5.1.1",
    "bcryptjs": "^3.0.2",
    "body-parser": "^2.2.0",
    "compression": "^1.8.0",
    "cookie-parser": "^1.4.7",
    "cors": "^2.8.5",
    "date-fns": "^4.1.0",
    "dotenv": "^16.4.7",
    "express": "^4.21.0",
    "express-rate-limit": "^7.5.1",
    "express-validator": "^7.2.1",
    "helmet": "^8.1.0",
    "jsonwebtoken": "^9.0.2",
    "pg": "^8.13.1",
    "pg-hstore": "^2.3.4",
    "sequelize": "^6.37.5",
    "sequelize-typescript": "^2.1.6",
    "ts-node": "^10.9.2",
    "yocto-queue": "^1.2.0"
  },
  "devDependencies": {
    "@types/cors": "^2.8.17",
    "@types/date-fns": "^2.6.3",
    "@typescript-eslint/eslint-plugin": "^7.18.0",
    "@typescript-eslint/parser": "^7.18.0",
    "eslint": "^8.57.1",
    "eslint-config-airbnb-base": "^15.0.0",
    "eslint-config-airbnb-typescript": "^18.0.0",
    "eslint-config-prettier": "^10.1.5",
    "eslint-plugin-import": "^2.32.0",
    "eslint-plugin-prettier": "^5.5.1",
    "eslint-plugin-security": "^3.0.1",
    "prettier": "^3.6.2",
    "sequelize-cli": "^6.6.2",
    "typescript": "^5.7.3"
  },
  "engines": {
    "node": ">=20"
  },
  "lint-staged": {
    "*.{js,ts,tsx}": [
      "npm run lint"
    ]
  }
}
