# Database Configuration
DB_USERNAME=postgres
DB_PASSWORD=your_secure_password
DB_NAME=choferes
DB_HOST=127.0.0.1
DB_PORT=5432

# JWT Configuration
JWT_SECRET_KEY=your_jwt_secret_key_here_minimum_32_characters
JWT_SECRET_KEY_REFRESH=your_jwt_refresh_secret_key_here_minimum_32_characters

# Server Configuration
PORT=5000
NODE_ENV=development

# CORS Configuration
REACT_APP_UI_URL=https://choferesdealquilercr.vercel.app

# Production Database (if using different service)
PGUSER=your_production_db_user
PGPASSWORD=your_production_db_password
PGDATABASE=your_production_db_name
PGHOST=your_production_db_host 