{
  "name": "choferes",
  "private": true,
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "turbo dev",
    "build": "turbo build",
    "test": "turbo test",
    "lint": "turbo lint",
    "format": "turbo format",
    "render-build": "NODE_ENV=development npm install && npx turbo build --filter=@choferes/backend",
    "postinstall": "husky install || true"
  },
  "devDependencies": {
    "husky": "^9.1.7",
    "jest": "^30.4.2",
    "lint-staged": "^16.1.2",
    "turbo": "^2.5.0"
  },
  "lint-staged": {
    "*.{js,jsx,ts,tsx}": [
      "eslint --fix"
    ]
  },
  "packageManager": "npm@10.9.2"
}
