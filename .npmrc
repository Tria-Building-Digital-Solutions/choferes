# ============================================================
# npm Workspaces Configuration
# ============================================================
# Use hoisted install strategy (default) for efficient disk usage.
# Dependency conflicts (e.g., Jest internal package mismatches)
# are resolved via "overrides" in the root package.json.
# ============================================================
install-strategy=hoisted

# ============================================================
# Save exact versions to package.json
# Prevents unexpected version changes across environments.
# ============================================================
save-exact=true

# ============================================================
# Suppress non-critical audit warnings on every install
# ============================================================
audit-level=critical
