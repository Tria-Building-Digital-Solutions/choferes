{
  "compilerOptions": {
    "target": "ES2020",
    "module": "node16",
    "lib": ["ES2020"],
    "types": ["node"],
    "outDir": "./dist",
    "rootDir": ".",
    "strict": true,
    "moduleResolution": "node16",
    "esModuleInterop": true,
    "skipLibCheck": true,
    "resolveJsonModule": true,
    "allowJs": true,
    "noImplicitAny": false,
    "declaration": true,
    "sourceMap": true,
    "forceConsistentCasingInFileNames": true,
    "paths": {
      "*": ["./*"],
      "sequelize": ["./types/sequelize.d.ts"]
    }
  },
  "include": ["src/**/*.ts", "test.js"],
  "exclude": ["node_modules", "dist", "src/__tests__"]
}
